# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/harda_db
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/harda_test_db
POSTGRES_PASSWORD=change-me-strong-password

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-32-char-random-string
JWT_SECRET_KEY=change-me-another-32-char-string
FLASK_ENV=production

# ── Google APIs ───────────────────────────────────────────────────────────────
# Used by backend geocoding + frontend map + mobile native maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Frontend (baked in at Docker build time via VITE_ prefix) ─────────────────
# Set this to your homelab IP or domain, e.g. http://192.168.1.10:5000/api/v1
# For the fyp.aliharizanuari.org setup, point this at the public API path, e.g.
#   https://fyp.aliharizanuari.org/api/v1   (if Caddy proxies /api to the backend)
VITE_API_BASE_URL=http://YOUR_HOMELAB_IP:5000/api/v1

# ── CORS (NFR6/NFR9) ──────────────────────────────────────────────────────────
# Comma-separated allowed origins. "*" allows any (dev only). In production set
# this to the site origin so the browser can call the API cross-origin, e.g.
#   CORS_ORIGINS=https://fyp.aliharizanuari.org
# (Not needed if Caddy serves the SPA and the API under the SAME origin.)
CORS_ORIGINS=*

# ── Rate limiting (NFR8) ──────────────────────────────────────────────────────
# memory:// is per-process — with >1 Gunicorn worker, point at Redis for a
# shared, accurate counter, e.g. RATELIMIT_STORAGE_URI=redis://redis:6379
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per minute
RATELIMIT_AUTH=10 per minute
RATELIMIT_DETECTION=30 per minute

# ── YOLO ──────────────────────────────────────────────────────────────────────
# Production weights are the fine-tuned pothole model; yolov8n.pt is the COCO
# placeholder. The compose bind-mounts ./ml/weights → /app/ml/weights (read-only).
YOLO_MODEL_PATH=ml/weights/pothole_yolov8s.pt
YOLO_CONFIDENCE_THRESHOLD=0.70

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads/
MAX_CONTENT_LENGTH=10485760
