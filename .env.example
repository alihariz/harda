# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/harda_db
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/harda_test_db
POSTGRES_PASSWORD=change-me-strong-password

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-32-char-random-string
JWT_SECRET_KEY=change-me-another-32-char-string
FLASK_ENV=production

# ── Google APIs ───────────────────────────────────────────────────────────────
# Used by backend geocoding + frontend map + mobile native maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Frontend (baked in at Docker build time via VITE_ prefix) ─────────────────
# Set this to your homelab IP or domain, e.g. http://192.168.1.10:5000/api/v1
VITE_API_BASE_URL=http://YOUR_HOMELAB_IP:5000/api/v1

# ── YOLO ──────────────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=ml/weights/yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.70

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads/
MAX_CONTENT_LENGTH=10485760
