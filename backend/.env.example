# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/harda_db
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/harda_test_db

# Flask
SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-here
FLASK_ENV=development

# Google APIs
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
GOOGLE_CLOUD_STORAGE_BUCKET=harda-images

# YOLO
YOLO_MODEL_PATH=ml/weights/yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.70

# File Upload
UPLOAD_FOLDER=uploads/
MAX_CONTENT_LENGTH=10485760

# CORS (NFR6/NFR9) — comma-separated allowed origins. "*" = allow any (dev only).
# When the homelab domain is ready, set e.g.
#   CORS_ORIGINS=https://harda.example.com,https://www.harda.example.com
CORS_ORIGINS=*

# Rate limiting (NFR8). RATELIMIT_ENABLED=false turns it off entirely.
# Storage is in-memory by default; point RATELIMIT_STORAGE_URI at redis:// for
# multi-worker production (e.g. redis://localhost:6379).
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per minute
RATELIMIT_AUTH=10 per minute
RATELIMIT_DETECTION=30 per minute
