{
  "expo": {
    "name": "HARDA",
    "slug": "harda-mobile",
    "version": "0.2.0",
    "orientation": "portrait",
    "scheme": "harda",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0F172A",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "my.edu.utm.harda",
      "infoPlist": {
        "NSCameraUsageDescription": "HARDA uses your camera to capture road hazard photos so they can be analysed and reported.",
        "NSPhotoLibraryUsageDescription": "HARDA needs access to your photo library so you can pick existing hazard photos.",
        "NSLocationWhenInUseUsageDescription": "HARDA uses your location to geotag hazards you submit and show nearby reports on the map."
      }
    },
    "android": {
      "package": "my.edu.utm.harda",
      "adaptiveIcon": {
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HARDA to access your camera so you can capture hazard photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow HARDA to use your location to geotag hazards."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://fyp.aliharizanuari.org/api/v1",
      "apiBaseUrlIos": "https://fyp.aliharizanuari.org/api/v1",
      "apiBaseUrlDevice": "https://fyp.aliharizanuari.org/api/v1",
      "eas": {
        "projectId": "f94aa9cf-cc79-42dd-92c9-d236a714c177"
      }
    }
  }
}
